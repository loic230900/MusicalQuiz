<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="180dp" android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:strokeWidth="0dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/playlis_item_color">

        <ImageView
            android:id="@+id/playlistArtistImageView" android:layout_width="match_parent"
            android:layout_height="100dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_playlist" android:scaleType="centerCrop"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/playlistNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            tools:text="My Awesome Mix" />

        <TextView
            android:id="@+id/trackCountTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#A6A6A6"
            android:gravity="center_horizontal"
            android:layout_marginTop="2dp"
            tools:text="15 tracks" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
