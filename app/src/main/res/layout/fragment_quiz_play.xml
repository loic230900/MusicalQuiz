<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        tools:context=".view.fragments.QuizPlayFragment">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/quizProgressIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"
            app:trackColor="?attr/colorOnSurface"
            app:indicatorColor="?attr/colorPrimary"
            tools:progress="30"
            tools:max="100"/>

        <TextView
            android:id="@+id/questionNumberTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintTop_toBottomOf="@id/quizProgressIndicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            tools:text="Question 3 / 10" />

        <TextView
            android:id="@+id/questionPromptTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintTop_toBottomOf="@id/questionNumberTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            tools:text="Guess the song!" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/playPreviewButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_play"
            android:contentDescription="@string/play_preview"
            app:tint="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/questionPromptTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/previewStatusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintTop_toBottomOf="@id/playPreviewButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            tools:text="Playing... 0:15 / 0:30"/>

        <LinearLayout
            android:id="@+id/answerButtonsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" 
            app:layout_constraintTop_toBottomOf="@id/previewStatusTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"
            tools:visibility="visible">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/answerButton1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingVertical="12dp"
                android:textColor="?attr/colorOnSurface"
                app:strokeColor="?attr/colorOnSurface"
                tools:text="Answer Option 1" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/answerButton2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingVertical="12dp"
                android:textColor="?attr/colorOnSurface"
                app:strokeColor="?attr/colorOnSurface"
                tools:text="Answer Option 2" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/answerButton3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingVertical="12dp"
                android:textColor="?attr/colorOnSurface"
                app:strokeColor="?attr/colorOnSurface"
                tools:text="Answer Option 3" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/answerButton4"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:textColor="?attr/colorOnSurface"
                app:strokeColor="?attr/colorOnSurface"
                tools:text="Answer Option 4" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/fillBlanksInputContainer" 
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" 
            app:layout_constraintTop_toBottomOf="@id/previewStatusTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"
            tools:visibility="visible">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/answerInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_type_your_answer"
                app:boxStrokeColor="?attr/colorOnSurface"
                app:hintTextColor="?attr/colorOnSurfaceVariant">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/answerEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:imeOptions="actionDone"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/submitTextAnswerButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_submit"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorOnSurface"
                app:strokeColor="?attr/colorOnSurface"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/loadingIndicator"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="?attr/colorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="gone"/>

        <LinearLayout
            android:id="@+id/resultsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible">
            <TextView
                android:id="@+id/quizFinishedTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quiz_finished"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/scoreTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                tools:text="Your Score: 7 / 10"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backToQuizzesButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/back_to_quizzes"
                android:layout_marginTop="24dp"
                android:textColor="?attr/colorOnSurface"
                app:strokeColor="?attr/colorOnSurface"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
